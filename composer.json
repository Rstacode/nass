{
    "name": "rstacode/nass",
    "description": "Laravel SDK for Nass Payment Gateway - Iraq",
    "keywords": [
        "laravel",
        "nass",
        "payment",
        "iraq",
        "gateway",
        "sdk"
    ],
    "homepage": "https://github.com/rstacode/nass",
    "license": "MIT",
    "authors": [
        {
            "name": "Rstacode",
            "email": "rstacode@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Nass\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nass\\NassServiceProvider"
            ],
            "aliases": {
                "Nass": "Nass\\Facades\\Nass"
            }
        }
    },
    "support": {
        "issues": "https://github.com/rstacode/nass/issues",
        "source": "https://github.com/rstacode/nass"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
